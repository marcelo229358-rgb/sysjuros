# =============================================================================
# SysContabel — variáveis de produção (.env.prod)
# Copie para .env.prod na VPS e preencha os valores.
# NUNCA commite o arquivo .env.prod no Git.
#
# Gerar segredos fortes (rode na VPS ou localmente):
#   openssl rand -base64 32
# =============================================================================

# --- PostgreSQL (container postgres) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- Backend — conexão com o banco ---
# Hostname "postgres" = nome do serviço no docker-compose
# Exemplo de formato (substitua USER, PASSWORD e DB pelos valores acima):
# DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/DB?schema=public
DATABASE_URL=

# --- Backend — autenticação JWT ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Backend — CORS (URL pública do frontend) ---
# Exemplo: https://app.seudominio.com
FRONTEND_URL=

# --- Frontend — build Vite (URLs públicas, usadas no npm run build dentro do Docker) ---
# URL pública da API (mesmo domínio ou subdomínio exposto pelo NPM)
# Exemplo: https://api.seudominio.com
VITE_API_URL=

# UUID da empresa — preencha APÓS rodar o seed manualmente (ou use o ID fixo do seed demo)
VITE_EMPRESA_ID=

# --- Seed manual (opcional) ---
# Deixe "false" no dia a dia. Use "true" apenas uma vez para criar dados iniciais.
RUN_SEED=false

# --- WhatsApp / Evolution API (opcional) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=syscontabel
NOTIFICACAO_DIAS_ANTECEDENCIA=1

# --- Master da plataforma (painel /master) ---
MASTER_EMAIL=
MASTER_PASSWORD=
