generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilUsuario {
  ADMIN
  FINANCEIRO
  OPERADOR
}

enum PlanoEmpresa {
  BASICO
  PRO
  PREMIUM
}

enum TipoLancamentoMaster {
  PAGAR
  RECEBER
}

enum StatusLancamentoMaster {
  PENDENTE
  PAGO
  CANCELADO
}

enum StatusContrato {
  ATIVO
  INADIMPLENTE
  CANCELADO
  QUITADO
}

enum StatusParcela {
  PENDENTE
  PAGA
  VENCIDA
  CANCELADA
}

enum BillingPlanPeriod {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  LIFETIME
}

enum BillingSubscriptionStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum BillingLicenseStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum BillingPaymentStatus {
  PENDING
  APPROVED
  FAILED
  REFUNDED
  CHARGEBACK
}

enum BillingPaymentProvider {
  KIWIFY
  HOTMART
  ASAAS
  STRIPE
  MERCADO_PAGO
  MANUAL
}

enum BillingInvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

enum BillingCouponType {
  PERCENT
  FIXED
}

model Empresa {
  id            String   @id @default(uuid())
  nome          String
  cnpj          String?  @unique
  email         String
  telefone      String?
  taxaJurosMes  Decimal  @default(30.0)
  taxaMulta     Decimal  @default(2.0)
  plano         PlanoEmpresa @default(BASICO)
  modoEscuro    Boolean  @default(false)
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  usuarios      Usuario[]
  clientes      Cliente[]
  contratos     Contrato[]
  logs          LogAuditoria[]
  notificacoes  Notificacao[]
  lancamentosMaster MasterLancamento[]

  @@map("empresas")
}

model Usuario {
  id            String        @id @default(uuid())
  empresaId     String
  empresa       Empresa       @relation(fields: [empresaId], references: [id])
  nome          String
  email         String
  senhaHash     String
  perfil        PerfilUsuario @default(OPERADOR)
  isMaster         Boolean       @default(false)
  ativo            Boolean       @default(true)
  deveAlterarSenha Boolean       @default(false)
  criadoEm      DateTime      @default(now())
  atualizadoEm  DateTime      @updatedAt

  logs          LogAuditoria[]

  @@unique([empresaId, email])
  @@map("usuarios")
}

model Cliente {
  id            String   @id @default(uuid())
  empresaId     String
  empresa       Empresa  @relation(fields: [empresaId], references: [id])
  nome          String
  cpfCnpj       String?
  email         String?
  telefone      String?
  endereco      String?
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  contratos     Contrato[]

  @@unique([empresaId, cpfCnpj])
  @@map("clientes")
}

model Contrato {
  id             String          @id @default(uuid())
  empresaId      String
  empresa        Empresa         @relation(fields: [empresaId], references: [id])
  clienteId      String
  cliente        Cliente         @relation(fields: [clienteId], references: [id])
  numero         String
  valorTotal     Decimal
  numParcelas    Int
  dataInicio     DateTime
  taxaJurosMes   Decimal?
  taxaMulta      Decimal?
  status         StatusContrato  @default(ATIVO)
  observacoes    String?
  criadoEm       DateTime        @default(now())
  atualizadoEm   DateTime        @updatedAt

  parcelas       Parcela[]

  @@unique([empresaId, numero])
  @@map("contratos")
}

model Parcela {
  id                String        @id @default(uuid())
  empresaId         String
  contratoId        String
  contrato          Contrato      @relation(fields: [contratoId], references: [id])
  numero            Int
  valorOriginal     Decimal
  valorMulta        Decimal       @default(0)
  valorJuros        Decimal       @default(0)
  valorAtualizado   Decimal
  dataVencimento    DateTime
  dataPagamento     DateTime?
  status            StatusParcela @default(PENDENTE)
  criadoEm          DateTime      @default(now())
  atualizadoEm      DateTime      @updatedAt

  pagamentos        Pagamento[]

  @@index([empresaId, status])
  @@index([empresaId, dataVencimento])
  @@map("parcelas")
}

model Pagamento {
  id             String   @id @default(uuid())
  empresaId      String
  parcelaId      String
  parcela        Parcela  @relation(fields: [parcelaId], references: [id])
  valorPago      Decimal
  formaPagamento String
  dataPagamento  DateTime @default(now())
  observacoes    String?

  @@map("pagamentos")
}

model LogAuditoria {
  id          String   @id @default(uuid())
  empresaId   String
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  acao        String
  entidade    String
  entidadeId  String
  detalhes    Json?
  criadoEm    DateTime @default(now())

  @@index([empresaId, criadoEm])
  @@map("logs_auditoria")
}

model Notificacao {
  id          String   @id @default(uuid())
  empresaId   String
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
  usuarioId   String?
  titulo      String
  mensagem    String
  tipo        String?
  parcelaId   String?
  lida        Boolean  @default(false)
  criadoEm    DateTime @default(now())

  @@index([empresaId, lida])
  @@index([empresaId, tipo, parcelaId])
  @@map("notificacoes")
}

model MasterLancamento {
  id          String                 @id @default(uuid())
  tipo        TipoLancamentoMaster
  descricao   String
  valor       Decimal
  vencimento  DateTime
  status      StatusLancamentoMaster @default(PENDENTE)
  empresaId   String?
  empresa     Empresa?               @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  criadoEm    DateTime               @default(now())
  atualizadoEm DateTime              @updatedAt

  @@index([tipo, status])
  @@map("master_lancamentos")
}

model MasterPermissao {
  id           String   @id @default(uuid())
  perfil       String
  modulo       String
  acoes        Json
  atualizadoEm DateTime @updatedAt

  @@unique([perfil, modulo])
  @@map("master_permissions")
}

model MasterAuditLog {
  id         String   @id @default(uuid())
  usuarioId  String?
  acao       String
  modulo     String
  detalhes   Json?
  ip         String?
  criadoEm   DateTime @default(now())

  @@index([criadoEm])
  @@index([modulo])
  @@map("master_audit_logs")
}

// =============================================================================
// AppDeploy Billing Platform (SaaS — não confundir com cobranças do tenant)
// =============================================================================

model BillingProduct {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  plans         BillingPlan[]
  subscriptions BillingSubscription[]

  @@map("billing_products")
}

model BillingPlan {
  id          String            @id @default(uuid())
  productId   String            @map("product_id")
  product     BillingProduct    @relation(fields: [productId], references: [id])
  name        String
  slug        String
  description String?
  price       Decimal
  currency    String            @default("BRL")
  period      BillingPlanPeriod @default(MONTHLY)
  active      Boolean           @default(true)
  limits      Json              @default("{}")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  planFeatures  BillingPlanFeature[]
  subscriptions BillingSubscription[]
  trials        BillingTrial[]

  @@unique([productId, slug])
  @@map("billing_plans")
}

model BillingFeature {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  planFeatures BillingPlanFeature[]

  @@map("billing_features")
}

model BillingPlanFeature {
  id        String         @id @default(uuid())
  planId    String         @map("plan_id")
  plan      BillingPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureId String         @map("feature_id")
  feature   BillingFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([planId, featureId])
  @@map("billing_plan_features")
}

model BillingSubscription {
  id          String                    @id @default(uuid())
  tenantId    String                    @map("tenant_id")
  productId   String                    @map("product_id")
  product     BillingProduct            @relation(fields: [productId], references: [id])
  planId      String                    @map("plan_id")
  plan        BillingPlan               @relation(fields: [planId], references: [id])
  status      BillingSubscriptionStatus @default(ACTIVE)
  startedAt   DateTime                  @default(now()) @map("started_at")
  expiresAt   DateTime?                 @map("expires_at")
  cancelledAt DateTime?                 @map("cancelled_at")
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")

  licenses BillingLicense[]
  payments BillingPayment[]
  invoices BillingInvoice[]
  logs     BillingSubscriptionLog[]

  @@index([tenantId, productId])
  @@index([status])
  @@map("billing_subscriptions")
}

model BillingLicense {
  id             String               @id @default(uuid())
  tenantId       String               @map("tenant_id")
  subscriptionId String               @map("subscription_id")
  subscription   BillingSubscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  status         BillingLicenseStatus @default(ACTIVE)
  limits         Json                 @default("{}")
  features       Json                 @default("[]")
  expiresAt      DateTime?            @map("expires_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([status])
  @@map("billing_licenses")
}

model BillingPayment {
  id             String                 @id @default(uuid())
  subscriptionId String                 @map("subscription_id")
  subscription   BillingSubscription  @relation(fields: [subscriptionId], references: [id])
  provider       BillingPaymentProvider
  externalId     String                 @map("external_id")
  status         BillingPaymentStatus   @default(PENDING)
  amount         Decimal
  currency       String                 @default("BRL")
  paidAt         DateTime?              @map("paid_at")
  createdAt      DateTime               @default(now()) @map("created_at")

  @@unique([provider, externalId])
  @@index([subscriptionId])
  @@map("billing_payments")
}

model BillingInvoice {
  id             String               @id @default(uuid())
  subscriptionId String               @map("subscription_id")
  subscription   BillingSubscription  @relation(fields: [subscriptionId], references: [id])
  amount         Decimal
  currency       String               @default("BRL")
  status         BillingInvoiceStatus @default(PENDING)
  dueAt          DateTime?            @map("due_at")
  paidAt         DateTime?            @map("paid_at")
  createdAt      DateTime             @default(now()) @map("created_at")

  @@index([subscriptionId])
  @@map("billing_invoices")
}

model BillingTrial {
  id        String      @id @default(uuid())
  tenantId  String      @map("tenant_id")
  productId String      @map("product_id")
  planId    String      @map("plan_id")
  plan      BillingPlan @relation(fields: [planId], references: [id])
  days      Int         @default(7)
  startedAt DateTime    @default(now()) @map("started_at")
  expiresAt DateTime    @map("expires_at")
  active    Boolean     @default(true)
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([tenantId, productId])
  @@map("billing_trials")
}

model BillingCoupon {
  id             String            @id @default(uuid())
  code           String            @unique
  type           BillingCouponType
  value          Decimal
  maxUses        Int?              @map("max_uses")
  usedCount      Int               @default(0) @map("used_count")
  expiresAt      DateTime?         @map("expires_at")
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now()) @map("created_at")

  @@map("billing_coupons")
}

model BillingWebhookLog {
  id         String                 @id @default(uuid())
  provider   BillingPaymentProvider
  externalId String                 @map("external_id")
  payload    Json
  processed  Boolean                @default(false)
  createdAt  DateTime               @default(now()) @map("created_at")

  @@unique([provider, externalId])
  @@map("billing_webhook_logs")
}

model BillingEvent {
  id        String   @id @default(uuid())
  type      String
  tenantId  String?  @map("tenant_id")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@map("billing_events")
}

model BillingSubscriptionLog {
  id             String              @id @default(uuid())
  subscriptionId String              @map("subscription_id")
  subscription   BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  action         String
  details        Json?
  createdAt      DateTime            @default(now()) @map("created_at")

  @@index([subscriptionId])
  @@map("billing_subscription_logs")
}

model BillingAuditLog {
  id        String   @id @default(uuid())
  tenantId  String?  @map("tenant_id")
  action    String
  module    String
  details   Json?
  actorId   String?  @map("actor_id")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([module])
  @@map("billing_audit_logs")
}
