# VPS deploy — variáveis locais (NÃO commitar vps.env.local)
# Copie para vps.env.local e preencha.

VPS_HOST=your.vps.ip.or.hostname
VPS_PORT=22
VPS_USER=root
VPS_DEPLOY_DIR=/root/sysjuros

# Autenticação — use chave SSH (recomendado) OU senha
# VPS_SSH_KEY_PATH=C:\Users\you\.ssh\id_rsa
# VPS_SSH_PASSPHRASE=
# VPS_PASSWORD=
