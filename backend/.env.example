# Servidor
PORT=3333
NODE_ENV=development

# Banco de dados
DATABASE_URL="postgresql://sysjuros:sysjuros123@localhost:5432/sysjuros?schema=public"

# JWT
JWT_SECRET="altere-esta-chave-em-producao"
JWT_EXPIRES_IN="7d"

# URL do frontend (CORS) — em produção use a URL pública
# FRONTEND_URL=https://sysjuros-web.onrender.com

# Evolution API (WhatsApp) — opcional, pode rodar em outro servidor (ex. Hostinger)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-chave-aqui
EVOLUTION_INSTANCE=sysjuros

# Lembretes automáticos (dias antes do vencimento)
NOTIFICACAO_DIAS_ANTECEDENCIA=1

# Master da plataforma (painel /master — criar novas empresas SysJuros)
MASTER_EMAIL=master@sysjuros.local
MASTER_PASSWORD=master123456
